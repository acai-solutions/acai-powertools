# Generated by terraform-testlab-setup and published as GitHub secret AWS_TESTBED_TFVARS.
# The workflow writes this as <env>.environment.tfvars into test/terratest/ before
# running tests. The Go test copies it into the temp terraformDir as environment.tfvars.
# Backend config (bucket, table, region) is stored as separate secrets and injected
# via BackendConfig in terraform.Options — variables cannot be used in backend blocks.

account_ids = {
  org_mgmt      = 471112796356
  core_logging  = 661921292302
  core_security = 668679959515
  core_backup   = 751861125367
  workload      = 839408459388
}

aws_region          = eu-central-1
aws_partition       = aws
aws_endpoint_domain = amazonaws.com

iam_role_name = OrganizationAccountAccessRole

